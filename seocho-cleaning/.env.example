# Google Apps Script 웹 앱 URL (배포 후 받은 /exec URL)
APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfy.../exec

# 관리자 대시보드 접근 키 (Apps Script 스크립트 속성의 ADMIN_KEY와 동일하게)
ADMIN_KEY=replace-with-strong-random-string

# 제출 API 공유 시크릿 (외부 가짜 제출 차단용)
# Apps Script 스크립트 속성의 SUBMIT_SECRET 와 동일하게 설정
SUBMIT_SECRET=replace-with-another-strong-random-string
